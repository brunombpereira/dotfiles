[user]
	name = Bruno Borlido Pereira
	email = brunoborlido@gmail.com

[init]
	defaultBranch = main

[pull]
	rebase = true

[push]
	autoSetupRemote = true
	default = current

[core]
	editor = nvim
	autocrlf = input
	excludesfile = ~/.gitignore_global

[color]
	ui = auto

[alias]
	st = status -sb
	co = checkout
	ci = commit
	br = branch
	lg = log --oneline --graph --decorate -20
	last = log -1 HEAD --stat
	unstage = reset HEAD --
	amend = commit --amend --no-edit

[diff]
	colorMoved = zebra

[merge]
	conflictStyle = zdiff3

[rerere]
	enabled = true

# Load ~/.gitconfig.local last so it overrides anything above.
# Forkers: drop your own [user] / [commit] / signing blocks there
# instead of editing this file. (Missing file is silently ignored.)
[include]
	path = ~/.gitconfig.local
